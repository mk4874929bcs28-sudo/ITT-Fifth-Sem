class Solution {
    public boolean carPooling(int[][] trips, int capacity) {
        int[] milestoneChanges = new int[1001];
        for (int[] trip : trips) {
            int passengers = trip[0];
            int from = trip[1];
            int to = trip[2];
            
            milestoneChanges[from] += passengers; 
            milestoneChanges[to] -= passengers;   
        }
        int currentPassengers = 0;
        for (int passengersAtMilestone : milestoneChanges) {
            currentPassengers += passengersAtMilestone;
            if (currentPassengers > capacity) {
                return false;
            }
        }        
        return true;
    }
}
