#include <stdlib.h>
#include <math.h>

int* findDuplicates(int* nums, int numsSize, int* returnSize) {
    int* result = (int*)malloc(numsSize * sizeof(int));
    *returnSize = 0;

    for (int i = 0; i < numsSize; i++) {
        int val = abs(nums[i]);
        int idx = val - 1;

        if (nums[idx] < 0) {
            result[*returnSize] = val;
            (*returnSize)++;
        } else {
            nums[idx] = -nums[idx];
        }
    }

    return result;
}
