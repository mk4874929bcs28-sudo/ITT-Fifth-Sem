#include <stdlib.h>
#include <string.h>
int* sortArray(int* nums, int numsSize, int* returnSize) {
    *returnSize = numsSize;
    
    int count[100005] = {0};
    
    for (int i = 0; i < numsSize; i++) {
        count[nums[i] + 50000]++;
    }
    
    int index = 0;
    for (int i = 0; i <= 100000; i++) {
        while (count[i] > 0) {
            nums[index] = i - 50000;
            index++;
            count[i]--;
        }
    }
    
    return nums;
}

